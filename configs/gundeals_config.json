    "page_param": "page",
    "max_pages": 20,
    "categories": {
        "handgun": "https://gun.deals/category/hand-guns",
        "hand-guns": "https://gun.deals/category/hand-guns",
        "shotgun": "https://gun.deals/category/shotguns",
        "shotguns": "https://gun.deals/category/shotguns",
        "rifle": "https://gun.deals/category/rifles",
        "rifles": "https://gun.deals/category/rifles"
    },
    "use_playwright": true,
    "wait_for_selector": ".tile--product",
    "items_selector": ".tile--product",
    "fields": {
        "name": ".tile__title a",
        "price": ".tile__price",
        "link": ".tile__title a"
    }
